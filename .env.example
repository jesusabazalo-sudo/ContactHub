VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA
VITE_OWNER_ADMIN_EMAIL=tu_correo_admin@ejemplo.com

# URL pública del sitio (sin barra final). Se usa para construir el redirect
# de OAuth (/auth/callback) y el link de recuperación de contraseña. Si se
# deja vacía, se usa window.location.origin en tiempo de ejecución.
VITE_SITE_URL=https://contact-hub-knmq.vercel.app
NEXT_PUBLIC_YAPE_NUMBER=TU_NUMERO_YAPE
NEXT_PUBLIC_PLIN_NUMBER=TU_NUMERO_PLIN
NEXT_PUBLIC_WHATSAPP_NUMBER=TU_NUMERO_WHATSAPP
NEXT_PUBLIC_PAYMENT_NAME=TU_NOMBRE_DE_PAGO
NEXT_PUBLIC_YAPE_QR_URL=/payments/yape-qr.jpeg
NEXT_PUBLIC_PLIN_QR_URL=

# --- Stripe (pago automático). Déjala VACÍA para mantener solo el flujo Yape manual. ---
# Llave PÚBLICA de Stripe (prueba: pk_test_...). Solo si está definida aparece el
# botón "Pagar con tarjeta". La llave SECRETA (sk_test_.../sk_live_...) y
# STRIPE_WEBHOOK_SECRET (whsec_...) NO van aquí: se configuran como secrets en
# Supabase (supabase secrets set STRIPE_SECRET_KEY=... STRIPE_WEBHOOK_SECRET=...).
VITE_STRIPE_PUBLIC_KEY=

# --- Datos legales (Términos, Privacidad, Devoluciones, Libro de Reclamaciones) ---
# Opcionales: si se dejan vacíos, se usan los valores por defecto en src/config/app.ts.
VITE_LEGAL_RUC=
VITE_LEGAL_DOMICILIO=
VITE_LEGAL_EMAIL=
